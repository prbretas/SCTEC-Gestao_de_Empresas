{
  "name": "sctec-gestao-empreendimentos",
  "version": "1.0.0",
  "description": "Portal de Gestao de Empreendimentos SC - SCTEC",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":80}}'",
    "lint": "eslint js/**/*.js --max-warnings=0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "setupFiles": [
      "./tests/setup.js"
    ]
  }
}
