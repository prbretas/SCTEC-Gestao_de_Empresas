#!/bin/sh
# pre-commit hook — executa testes antes de qualquer commit
# Instalar: cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "======================================"
echo "  SCTEC - Executando testes antes do commit..."
echo "======================================"

# Verifica se node_modules existe
if [ ! -d "node_modules" ]; then
  echo "Instalando dependencias..."
  npm install --silent
fi

# Executa os testes
npm test --silent

# Captura o codigo de saida
TEST_RESULT=$?

if [ $TEST_RESULT -ne 0 ]; then
  echo ""
  echo "======================================"
  echo "  COMMIT BLOQUEADO: Testes falharam!"
  echo "  Corrija os erros antes de commitar."
  echo "======================================"
  exit 1
fi

echo ""
echo "======================================"
echo "  Todos os testes passaram. Commit liberado."
echo "======================================"
exit 0
